{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TempoTerm",
  "version": "0.1.1",
  "identifier": "com.tempoterm.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TempoTerm",
        "width": 1200,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": true,
        "backgroundColor": "#222222"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://ipc.localhost; font-src 'none'; media-src 'none'; worker-src 'none'; object-src 'none'; frame-src 'none'; base-uri 'none'; form-action 'none'",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**", "/**"],
          "deny": [
            "**/.ssh/**",
            "**/.aws/**",
            "**/.gnupg/**",
            "**/.env",
            "**/.env.*",
            "**/*.pem",
            "**/*.key",
            "**/id_rsa*"
          ],
          "requireLiteralLeadingDot": true
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI2OUYzNUQ0RkUzMjE3RkQKUldUOUZ6TCsxRFdmdHM0Z05lQitTckl1YmVRTjNLM0NxV1luVzQwclQwaU9Lc09paXJLb21tS1MK",
      "endpoints": [
        "https://github.com/mukiwu/tempo-term/releases/latest/download/latest.json"
      ],
      "dialog": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": ["resources/zsh-autosuggestions.zsh"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "Developer ID Application: TZU YING WU (62629DYRU8)",
      "entitlements": "entitlements.plist"
    }
  }
}
