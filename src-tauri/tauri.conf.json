{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TempoTerm",
  "version": "0.0.1",
  "identifier": "com.tempoterm.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TempoTerm",
        "width": 1200,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhEMzJGM0RDNjg2NDU0NzEKUldSeFZHUm8zUE15alFBZ2NJdlIzMytPTEkxcFYxWXd4aG0wSUdNVkNMZDdoYmVLekl1M0RUM1cK",
